{
  "realm": "bankos",
  "displayName": "BankOS Platform",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "sslRequired": "none",
  "roles": {
    "realm": [
      { "name": "USER",       "description": "Standard bank user (read own accounts)" },
      { "name": "BACKOFFICE", "description": "Bank operator (debit, credit, freeze)" },
      { "name": "ADMIN",      "description": "Platform administrator" }
    ]
  },
  "clients": [
    {
      "clientId": "bankos-gateway",
      "secret": "bankos-gateway-secret",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": ["http://localhost:3000/*", "http://localhost:8080/*"],
      "webOrigins": ["http://localhost:3000", "http://localhost:8080"]
    }
  ],
  "users": [
    {
      "username": "user1",
      "email": "user1@bankos.demo",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["USER"]
    },
    {
      "username": "operator1",
      "email": "operator1@bankos.demo",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["USER", "BACKOFFICE"]
    },
    {
      "username": "admin1",
      "email": "admin1@bankos.demo",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["USER", "BACKOFFICE", "ADMIN"]
    }
  ]
}
